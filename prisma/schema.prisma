// Atlas — Wave 1 schema.
// All PKs are UUIDv7. All timestamps are TIMESTAMPTZ.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── User ────────────────────────────────────────────────────────────────────
// MAINTENANCE NOTE: When adding a new table with a user_id column, you MUST
// also update reattachOrphanData() in src/core/auth/orphan-recovery.ts to
// include that table in the orphan reattachment transaction.

model User {
  id                      String    @id @db.Uuid
  clerk_id                String    @unique
  email                   String    @unique
  name                    String?
  image                   String?
  timezone                String    @default("UTC")
  locale_preset           String    @default("pakistan")
  language                String    @default("ur")
  currency_code           String    @default("PKR")
  currency_symbol         String    @default("₨")
  date_format             String    @default("DD/MM/YYYY")
  number_format           String    @default("1,234.56")
  time_format             String    @default("12h")
  week_start              String    @default("monday")
  theme                   String    @default("dark")
  tasks_prefs             Json?
  ai_confidence_threshold Float     @default(0.70)
  ai_budget_usd           Float?
  recovery_notification_pending Boolean   @default(false)
  last_recovery_summary         Json?
  last_recovery_dismissed_at    DateTime? @db.Timestamptz
  created_at              DateTime  @default(now()) @db.Timestamptz
  updated_at              DateTime  @updatedAt @db.Timestamptz
  deleted_at              DateTime? @db.Timestamptz

  audit_logs              AuditLog[]
  integration_tokens      IntegrationToken[]
  sync_states             SyncState[]
  ai_call_logs            AICallLog[]
  attachments             Attachment[]
  drive_config            DriveConfig?
  captures                Capture[]
  email_captures          EmailCapture[]
  capture_parse_logs      CaptureParseLog[]
  tasks                   Task[]
  projects                Project[]
  project_folders         ProjectFolder[]
  contexts                Context[]
  tags                    Tag[]
  people                  Person[]
  checklist_items         ChecklistItem[]
  work_logs               TaskWorkLog[]
  notes                   Note[]
  notes_folders           NotesFolder[]
  links                   Link[]
  tables                  Table[]
  tables_folders          TablesFolder[]
  task_templates          TaskTemplate[]
  google_calendar_token   GoogleCalendarOAuthToken?
  google_calendars        GoogleCalendar[]
  calendar_events         CalendarEvent[]

  @@index([clerk_id])
  @@index([email])
  @@index([deleted_at])
}

// ─── AuditLog ────────────────────────────────────────────────────────────────

model AuditLog {
  id          String   @id @db.Uuid
  user_id     String?  @db.Uuid
  entity_type String
  entity_id   String
  action      String
  diff        Json?
  meta        Json?
  created_at  DateTime @default(now()) @db.Timestamptz

  user        User?    @relation(fields: [user_id], references: [id], onDelete: SetNull)

  @@index([user_id])
  @@index([entity_type, entity_id])
  @@index([created_at])
}

// ─── IntegrationToken ────────────────────────────────────────────────────────

model IntegrationToken {
  id            String   @id @db.Uuid
  user_id       String   @db.Uuid
  provider      String
  encrypted_data String
  scopes        String[]
  expires_at    DateTime? @db.Timestamptz
  created_at    DateTime @default(now()) @db.Timestamptz
  updated_at    DateTime @updatedAt @db.Timestamptz

  user          User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, provider])
  @@index([user_id])
}

// ─── SyncState ───────────────────────────────────────────────────────────────

model SyncState {
  id            String   @id @db.Uuid
  user_id       String   @db.Uuid
  provider      String
  resource_type String
  cursor        String?
  last_synced   DateTime? @db.Timestamptz
  meta          Json?
  created_at    DateTime @default(now()) @db.Timestamptz
  updated_at    DateTime @updatedAt @db.Timestamptz

  user          User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, provider, resource_type])
  @@index([user_id])
}

// ─── RateLimitTracker ────────────────────────────────────────────────────────

model RateLimitTracker {
  id          String   @id @db.Uuid
  user_id     String   @db.Uuid
  provider    String
  window_start DateTime @db.Timestamptz
  request_count Int    @default(0)
  daily_count Int      @default(0)
  updated_at  DateTime @updatedAt @db.Timestamptz

  @@unique([user_id, provider, window_start])
  @@index([user_id, provider])
}

// ─── AICallLog ───────────────────────────────────────────────────────────────

model AICallLog {
  id            String   @id @db.Uuid
  user_id       String?  @db.Uuid
  task          String
  model         String
  input_tokens  Int?
  output_tokens Int?
  cost_usd      Float?
  duration_ms   Int?
  success       Boolean  @default(true)
  error         String?
  created_at    DateTime @default(now()) @db.Timestamptz

  user          User?    @relation(fields: [user_id], references: [id], onDelete: SetNull)

  @@index([user_id])
  @@index([created_at])
  @@index([user_id, created_at])
}

// ─── Attachment ──────────────────────────────────────────────────────────────

model Attachment {
  id              String    @id @db.Uuid
  user_id         String    @db.Uuid
  task_id         String?   @db.Uuid
  parent_type     String?
  parent_id       String?
  file_id         String    @unique
  filename        String
  content_type    String
  size_bytes      Int
  storage_path    String
  thumbnail_path  String?
  position        Decimal   @default(0) @db.Decimal(20, 10)
  description     String?
  reviewed        Boolean   @default(false)
  image_width     Int?
  image_height    Int?
  deleted_at      DateTime? @db.Timestamptz
  created_at      DateTime  @default(now()) @db.Timestamptz
  updated_at      DateTime  @updatedAt @db.Timestamptz

  user            User              @relation(fields: [user_id], references: [id], onDelete: Cascade)
  task            Task?             @relation("TaskAttachments", fields: [task_id], references: [id], onDelete: SetNull)
  tags            TagOnAttachment[]

  @@index([user_id])
  @@index([task_id])
  @@index([parent_type, parent_id])
  @@index([user_id, reviewed])
  @@index([deleted_at])
}

// ─── TagOnAttachment (join) ──────────────────────────────────────────────────

model TagOnAttachment {
  attachment_id  String     @db.Uuid
  tag_id         String     @db.Uuid
  created_at     DateTime   @default(now()) @db.Timestamptz

  attachment     Attachment @relation(fields: [attachment_id], references: [id], onDelete: Cascade)
  tag            Tag        @relation(fields: [tag_id], references: [id], onDelete: Cascade)

  @@id([attachment_id, tag_id])
  @@index([tag_id])
}

// ─── Capture ─────────────────────────────────────────────────────────────────

model Capture {
  id                String    @id @db.Uuid
  user_id           String    @db.Uuid
  raw_text          String
  title             String?
  tags              String[]
  due_date          DateTime? @db.Timestamptz
  action_items      String[]
  ai_parsed         Boolean   @default(false)

  // GTD Inbox Wave 1 fields
  state             String    @default("raw") // raw | proposed | processed
  processed_at      DateTime? @db.Timestamptz
  processed_to_type String?   // "task" | "project" | "reference" | "someday" | "deleted"
  processed_to_id   String?   @db.Uuid
  migration_source  String?   // e.g. "inbox_migration_v1"
  parser_proposal   Json?     // structured ParsedCapture output from parser

  deleted_at   DateTime? @db.Timestamptz
  created_at   DateTime  @default(now()) @db.Timestamptz
  updated_at   DateTime  @updatedAt @db.Timestamptz

  user         User      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([user_id, created_at])
  @@index([user_id, state])
  @@index([user_id, state, processed_at])
  @@index([deleted_at])
}

// ─── Person ──────────────────────────────────────────────────────────────────
// MAINTENANCE NOTE: Person has a user_id column and is included in
// reattachOrphanData() in src/core/auth/orphan-recovery.ts.

model Person {
  id                  String    @id @db.Uuid
  user_id             String    @db.Uuid
  handle              String

  // Name decomposition (Google Contacts compatible)
  display_name        String?
  honorific_prefix    String?   // Mr., Dr., Prof., etc.
  given_name          String?
  middle_name         String?
  family_name         String?
  honorific_suffix    String?   // Jr., Sr., III, etc.
  nickname            String?

  // Profile
  biography           String?
  photo_url           String?

  // Relationship
  relationship_type   String?   // friend | colleague | family | client | advisor | mentor | acquaintance | custom

  // Cadence / follow-up (Wave 5a-ii)
  cadence_days                        Int?
  last_contacted_at                   DateTime? @db.Timestamptz  // = MAX(occurred_at) across non-deleted interactions; also accepts manual override
  next_follow_up_at                   DateTime? @db.Timestamptz  // = last_contacted_at + cadence_days (null when either is null)
  followup_snooze_until               DateTime? @db.Timestamptz  // snooze follow-up until this date
  cadence_suggestion_dismissed_at                  DateTime? @db.Timestamptz  // when user last dismissed cadence suggestion
  cadence_suggestion_dismissed_value               Int?                       // median gap (days) at time of dismissal
  cadence_suggestion_dismissed_interaction_count   Int?                       // non-deleted interaction count at dismissal time

  // External data blob for sync provenance
  external_data       Json?

  deleted_at          DateTime? @db.Timestamptz
  created_at          DateTime  @default(now()) @db.Timestamptz
  updated_at          DateTime  @updatedAt @db.Timestamptz

  user                User               @relation(fields: [user_id], references: [id], onDelete: Cascade)
  emails              PersonEmail[]
  phones              PersonPhone[]
  addresses           PersonAddress[]
  organizations       PersonOrganization[]
  urls                PersonUrl[]
  events              PersonEvent[]
  relations           PersonRelation[]   @relation("PersonRelations")
  reverse_relations   PersonRelation[]   @relation("PersonRelationTargets")
  skills              PersonSkill[]
  interests           PersonInterest[]
  tags                TagOnPerson[]
  interactions        PersonInteraction[]
  calendar_attendees  CalendarEventAttendee[]

  @@unique([user_id, handle])
  @@index([user_id])
  @@index([user_id, relationship_type])
  @@index([user_id, next_follow_up_at])
  @@index([user_id, followup_snooze_until])
  @@index([deleted_at])
}

// ─── PersonEmail ──────────────────────────────────────────────────────────────

model PersonEmail {
  id              String    @id @db.Uuid
  person_id       String    @db.Uuid
  email           String
  type            String    @default("other") // home | work | other | custom
  is_primary      Boolean   @default(false)
  source          String?   // google_contacts | manual | import
  source_id       String?
  source_metadata Json?
  last_synced_at  DateTime? @db.Timestamptz
  deleted_at      DateTime? @db.Timestamptz
  created_at      DateTime  @default(now()) @db.Timestamptz
  updated_at      DateTime  @updatedAt @db.Timestamptz

  person          Person    @relation(fields: [person_id], references: [id], onDelete: Cascade)

  @@index([person_id])
  @@index([person_id, is_primary])
  @@index([deleted_at])
}

// ─── PersonPhone ──────────────────────────────────────────────────────────────

model PersonPhone {
  id              String    @id @db.Uuid
  person_id       String    @db.Uuid
  number          String
  e164_normalized String?
  type            String    @default("other") // mobile | home | work | fax | other | custom
  is_primary      Boolean   @default(false)
  source          String?
  source_id       String?
  source_metadata Json?
  last_synced_at  DateTime? @db.Timestamptz
  deleted_at      DateTime? @db.Timestamptz
  created_at      DateTime  @default(now()) @db.Timestamptz
  updated_at      DateTime  @updatedAt @db.Timestamptz

  person          Person    @relation(fields: [person_id], references: [id], onDelete: Cascade)

  @@index([person_id])
  @@index([person_id, is_primary])
  @@index([deleted_at])
}

// ─── PersonAddress ────────────────────────────────────────────────────────────

model PersonAddress {
  id              String    @id @db.Uuid
  person_id       String    @db.Uuid
  type            String    @default("other") // home | work | other | custom
  street          String?
  city            String?
  region          String?   // state/province
  postal_code     String?
  country_code    String?   // ISO 3166-1 alpha-2
  country_name    String?
  formatted       String?   // full formatted address
  is_primary      Boolean   @default(false)
  source          String?
  source_id       String?
  source_metadata Json?
  last_synced_at  DateTime? @db.Timestamptz
  deleted_at      DateTime? @db.Timestamptz
  created_at      DateTime  @default(now()) @db.Timestamptz
  updated_at      DateTime  @updatedAt @db.Timestamptz

  person          Person    @relation(fields: [person_id], references: [id], onDelete: Cascade)

  @@index([person_id])
  @@index([person_id, is_primary])
  @@index([deleted_at])
}

// ─── PersonOrganization ───────────────────────────────────────────────────────

model PersonOrganization {
  id              String    @id @db.Uuid
  person_id       String    @db.Uuid
  name            String
  title           String?
  department      String?
  is_current      Boolean   @default(true)
  is_primary      Boolean   @default(false)
  start_date      DateTime? @db.Timestamptz
  end_date        DateTime? @db.Timestamptz
  source          String?
  source_id       String?
  source_metadata Json?
  last_synced_at  DateTime? @db.Timestamptz
  deleted_at      DateTime? @db.Timestamptz
  created_at      DateTime  @default(now()) @db.Timestamptz
  updated_at      DateTime  @updatedAt @db.Timestamptz

  person          Person    @relation(fields: [person_id], references: [id], onDelete: Cascade)

  @@index([person_id])
  @@index([person_id, is_primary])
  @@index([person_id, is_current])
  @@index([deleted_at])
}

// ─── PersonUrl ────────────────────────────────────────────────────────────────

model PersonUrl {
  id              String    @id @db.Uuid
  person_id       String    @db.Uuid
  url             String
  type            String    @default("other") // linkedin | twitter | github | website | other | custom
  label           String?
  source          String?
  source_id       String?
  source_metadata Json?
  last_synced_at  DateTime? @db.Timestamptz
  deleted_at      DateTime? @db.Timestamptz
  created_at      DateTime  @default(now()) @db.Timestamptz
  updated_at      DateTime  @updatedAt @db.Timestamptz

  person          Person    @relation(fields: [person_id], references: [id], onDelete: Cascade)

  @@index([person_id])
  @@index([deleted_at])
}

// ─── PersonEvent ─────────────────────────────────────────────────────────────

model PersonEvent {
  id              String    @id @db.Uuid
  person_id       String    @db.Uuid
  type            String    @default("other") // birthday | anniversary | other | custom
  date            DateTime  @db.Timestamptz
  label           String?
  source          String?
  source_id       String?
  source_metadata Json?
  last_synced_at  DateTime? @db.Timestamptz
  deleted_at      DateTime? @db.Timestamptz
  created_at      DateTime  @default(now()) @db.Timestamptz
  updated_at      DateTime  @updatedAt @db.Timestamptz

  person          Person    @relation(fields: [person_id], references: [id], onDelete: Cascade)

  @@index([person_id])
  @@index([deleted_at])
}

// ─── PersonRelation ───────────────────────────────────────────────────────────

model PersonRelation {
  id                String    @id @db.Uuid
  person_id         String    @db.Uuid
  related_person_id String?   @db.Uuid
  related_text      String?   // free-text name when no linked person
  type              String    @default("other") // spouse | partner | parent | child | sibling | friend | colleague | other | custom
  source            String?
  source_id         String?
  source_metadata   Json?
  last_synced_at    DateTime? @db.Timestamptz
  deleted_at        DateTime? @db.Timestamptz
  created_at        DateTime  @default(now()) @db.Timestamptz
  updated_at        DateTime  @updatedAt @db.Timestamptz

  person            Person    @relation("PersonRelations", fields: [person_id], references: [id], onDelete: Cascade)
  related_person    Person?   @relation("PersonRelationTargets", fields: [related_person_id], references: [id], onDelete: SetNull)

  @@index([person_id])
  @@index([related_person_id])
  @@index([deleted_at])
}

// ─── PersonSkill ──────────────────────────────────────────────────────────────

model PersonSkill {
  id              String    @id @db.Uuid
  person_id       String    @db.Uuid
  name            String
  source          String?
  source_id       String?
  source_metadata Json?
  last_synced_at  DateTime? @db.Timestamptz
  deleted_at      DateTime? @db.Timestamptz
  created_at      DateTime  @default(now()) @db.Timestamptz
  updated_at      DateTime  @updatedAt @db.Timestamptz

  person          Person    @relation(fields: [person_id], references: [id], onDelete: Cascade)

  @@index([person_id])
  @@index([deleted_at])
}

// ─── PersonInterest ───────────────────────────────────────────────────────────

model PersonInterest {
  id              String    @id @db.Uuid
  person_id       String    @db.Uuid
  name            String
  source          String?
  source_id       String?
  source_metadata Json?
  last_synced_at  DateTime? @db.Timestamptz
  deleted_at      DateTime? @db.Timestamptz
  created_at      DateTime  @default(now()) @db.Timestamptz
  updated_at      DateTime  @updatedAt @db.Timestamptz

  person          Person    @relation(fields: [person_id], references: [id], onDelete: Cascade)

  @@index([person_id])
  @@index([deleted_at])
}

// ─── PersonInteraction ────────────────────────────────────────────────────────
// MAINTENANCE NOTE: PersonInteraction cascades through person_id → person.user_id.
// It does NOT have a direct user_id column, so reattachOrphanData() handles it
// indirectly via person reattachment. No explicit entry needed.

model PersonInteraction {
  id                String    @id @db.Uuid
  person_id         String    @db.Uuid

  // What kind of interaction this was (normalized lowercase, 1-32 chars)
  kind              String    // meeting | call | message | email | coffee | lunch | dinner | note | other | custom

  occurred_at       DateTime  @db.Timestamptz
  duration_minutes  Int?      // 0–1440
  location          String?   // free text, max 500 chars
  notes             String?   // max 10 000 chars

  // Optional links back to source entities (same user validated in router)
  source_capture_id String?   @db.Uuid
  source_task_id    String?   @db.Uuid

  deleted_at        DateTime? @db.Timestamptz
  created_at        DateTime  @default(now()) @db.Timestamptz
  updated_at        DateTime  @updatedAt @db.Timestamptz

  person            Person    @relation(fields: [person_id], references: [id], onDelete: Cascade)

  @@index([person_id])
  @@index([person_id, occurred_at])
  @@index([person_id, deleted_at])
  @@index([deleted_at])
}

// ─── TagOnPerson (join) ───────────────────────────────────────────────────────

model TagOnPerson {
  person_id  String   @db.Uuid
  tag_id     String   @db.Uuid
  created_at DateTime @default(now()) @db.Timestamptz

  person     Person   @relation(fields: [person_id], references: [id], onDelete: Cascade)
  tag        Tag      @relation(fields: [tag_id], references: [id], onDelete: Cascade)

  @@id([person_id, tag_id])
  @@index([tag_id])
}

// ─── Tag ─────────────────────────────────────────────────────────────────────

model Tag {
  id          String    @id @db.Uuid
  user_id     String    @db.Uuid
  name        String
  color       String?
  usage_count Int       @default(0)
  deleted_at  DateTime? @db.Timestamptz
  created_at  DateTime  @default(now()) @db.Timestamptz
  updated_at  DateTime  @updatedAt @db.Timestamptz

  user        User      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  tasks       TagOnTask[]
  attachments TagOnAttachment[]
  tag_on_notes TagOnNote[]
  templates   TagOnTaskTemplate[]
  people      TagOnPerson[]

  @@unique([user_id, name])
  @@index([user_id])
  @@index([user_id, usage_count])
  @@index([deleted_at])
}

// ─── Context ─────────────────────────────────────────────────────────────────

model Context {
  id         String    @id @db.Uuid
  user_id    String    @db.Uuid
  name       String
  icon       String?
  color      String?
  position   Decimal   @default(0) @db.Decimal(20, 10)
  deleted_at DateTime? @db.Timestamptz
  created_at DateTime  @default(now()) @db.Timestamptz
  updated_at DateTime  @updatedAt @db.Timestamptz

  user       User      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  tasks      ContextOnTask[]
  templates  ContextOnTaskTemplate[]

  @@unique([user_id, name])
  @@index([user_id])
  @@index([deleted_at])
}

// ─── ProjectFolder ────────────────────────────────────────────────────────────

model ProjectFolder {
  id          String    @id @db.Uuid
  user_id     String    @db.Uuid
  parent_id   String?   @db.Uuid
  name        String
  notes       String?
  position    Decimal   @default(0) @db.Decimal(20, 10)
  collapsed   Boolean   @default(false)
  deleted_at  DateTime? @db.Timestamptz
  created_at  DateTime  @default(now()) @db.Timestamptz
  updated_at  DateTime  @updatedAt @db.Timestamptz

  user        User            @relation(fields: [user_id], references: [id], onDelete: Cascade)
  parent      ProjectFolder?  @relation("FolderChildren", fields: [parent_id], references: [id], onDelete: SetNull)
  children    ProjectFolder[] @relation("FolderChildren")
  projects    Project[]

  @@index([user_id])
  @@index([user_id, parent_id])
  @@index([deleted_at])
}

// ─── Project ─────────────────────────────────────────────────────────────────

model Project {
  id                   String    @id @db.Uuid
  user_id              String    @db.Uuid
  folder_id            String?   @db.Uuid
  title                String
  notes                String?
  type                 String    @default("project") // project | area
  status               String    @default("active") // active | on_hold | completed | dropped
  target_date          DateTime? @db.Timestamptz
  color                String?
  sequential           Boolean   @default(false)
  position             Decimal   @default(0) @db.Decimal(20, 10)
  completed_at         DateTime? @db.Timestamptz
  last_reviewed_at     DateTime? @db.Timestamptz
  review_interval_days Int?      // null = Never; 3, 7, 14, 30
  // Tracker fields — all nullable; cleared automatically via onDelete:SetNull when source is removed
  tracker_table_id     String?   @db.Uuid
  tracker_column_id    String?   @db.Uuid
  tracker_aggregation  String?   // sum | average | count | min | max | checked_ratio
  tracker_target_value Float?
  tracker_target_label String?
  deleted_at           DateTime? @db.Timestamptz
  created_at           DateTime  @default(now()) @db.Timestamptz
  updated_at           DateTime  @updatedAt @db.Timestamptz

  user             User           @relation(fields: [user_id], references: [id], onDelete: Cascade)
  folder           ProjectFolder? @relation(fields: [folder_id], references: [id], onDelete: SetNull)
  tracker_table    Table?         @relation("ProjectTrackerTable", fields: [tracker_table_id], references: [id], onDelete: SetNull)
  tracker_column   TableColumn?   @relation("ProjectTrackerColumn", fields: [tracker_column_id], references: [id], onDelete: SetNull)
  tasks            Task[]
  note_refs        Note[]
  tables           Table[]        @relation("TableProject")
  task_templates   TaskTemplate[] @relation("TaskTemplateDefaultProject")
  calendar_events  CalendarEvent[] @relation("CalendarEventProject")

  @@index([user_id])
  @@index([user_id, type])
  @@index([user_id, status])
  @@index([user_id, position])
  @@index([user_id, folder_id])
  @@index([deleted_at])
}

// ─── Task ────────────────────────────────────────────────────────────────────

model Task {
  id          String    @id @db.Uuid
  user_id     String    @db.Uuid
  project_id  String?   @db.Uuid
  parent_id   String?   @db.Uuid
  title       String
  notes       String?
  status      String    @default("active") // active | completed | dropped
  flagged     Boolean   @default(false)
  defer_date  DateTime? @db.Timestamptz
