// Atlas — Wave 1 schema.
// All PKs are UUIDv7. All timestamps are TIMESTAMPTZ.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── User ────────────────────────────────────────────────────────────────────

model User {
  id                      String    @id @db.Uuid
  clerk_id                String?   @unique
  email                   String    @unique
  name                    String?
  image                   String?
  timezone                String    @default("UTC")
  date_format             String    @default("DD/MM/YYYY")
  time_format             String    @default("24h")
  week_start              String    @default("monday")
  theme                   String    @default("dark")
  tasks_prefs             Json?
  ai_confidence_threshold Float     @default(0.70)
  created_at              DateTime  @default(now()) @db.Timestamptz
  updated_at              DateTime  @updatedAt @db.Timestamptz
  deleted_at              DateTime? @db.Timestamptz

  audit_logs         AuditLog[]
  integration_tokens IntegrationToken[]
  sync_states        SyncState[]
  ai_call_logs       AICallLog[]
  attachments        Attachment[]
  drive_config       DriveConfig?
  captures           Capture[]
  email_captures     EmailCapture[]
  capture_parse_logs CaptureParseLog[]
  tasks              Task[]
  projects           Project[]
  project_folders    ProjectFolder[]
  contexts           Context[]
  tags               Tag[]
  people             Person[]
  checklist_items    ChecklistItem[]
  work_logs          TaskWorkLog[]

  @@index([clerk_id])
  @@index([email])
  @@index([deleted_at])
}

// ─── AuditLog ────────────────────────────────────────────────────────────────

model AuditLog {
  id          String   @id @db.Uuid
  user_id     String?  @db.Uuid
  entity_type String
  entity_id   String
  action      String
  diff        Json?
  meta        Json?
  created_at  DateTime @default(now()) @db.Timestamptz

  user        User?    @relation(fields: [user_id], references: [id], onDelete: SetNull)

  @@index([user_id])
  @@index([entity_type, entity_id])
  @@index([created_at])
}

// ─── IntegrationToken ────────────────────────────────────────────────────────

model IntegrationToken {
  id            String   @id @db.Uuid
  user_id       String   @db.Uuid
  provider      String
  encrypted_data String
  scopes        String[]
  expires_at    DateTime? @db.Timestamptz
  created_at    DateTime @default(now()) @db.Timestamptz
  updated_at    DateTime @updatedAt @db.Timestamptz

  user          User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, provider])
  @@index([user_id])
}

// ─── SyncState ───────────────────────────────────────────────────────────────

model SyncState {
  id            String   @id @db.Uuid
  user_id       String   @db.Uuid
  provider      String
  resource_type String
  cursor        String?
  last_synced   DateTime? @db.Timestamptz
  meta          Json?
  created_at    DateTime @default(now()) @db.Timestamptz
  updated_at    DateTime @updatedAt @db.Timestamptz

  user          User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, provider, resource_type])
  @@index([user_id])
}

// ─── RateLimitTracker ────────────────────────────────────────────────────────

model RateLimitTracker {
  id          String   @id @db.Uuid
  user_id     String   @db.Uuid
  provider    String
  window_start DateTime @db.Timestamptz
  request_count Int    @default(0)
  daily_count Int      @default(0)
  updated_at  DateTime @updatedAt @db.Timestamptz

  @@unique([user_id, provider, window_start])
  @@index([user_id, provider])
}

// ─── AICallLog ───────────────────────────────────────────────────────────────

model AICallLog {
  id            String   @id @db.Uuid
  user_id       String?  @db.Uuid
  task          String
  model         String
  input_tokens  Int?
  output_tokens Int?
  cost_usd      Float?
  duration_ms   Int?
  success       Boolean  @default(true)
  error         String?
  created_at    DateTime @default(now()) @db.Timestamptz

  user          User?    @relation(fields: [user_id], references: [id], onDelete: SetNull)

  @@index([user_id])
  @@index([created_at])
  @@index([user_id, created_at])
}

// ─── Attachment ──────────────────────────────────────────────────────────────

model Attachment {
  id              String    @id @db.Uuid
  user_id         String    @db.Uuid
  task_id         String?   @db.Uuid
  parent_type     String?
  parent_id       String?
  file_id         String    @unique
  filename        String
  content_type    String
  size_bytes      Int
  storage_path    String
  thumbnail_path  String?
  position        Decimal   @default(0) @db.Decimal(20, 10)
  description     String?
  reviewed        Boolean   @default(false)
  image_width     Int?
  image_height    Int?
  deleted_at      DateTime? @db.Timestamptz
  created_at      DateTime  @default(now()) @db.Timestamptz
  updated_at      DateTime  @updatedAt @db.Timestamptz

  user            User              @relation(fields: [user_id], references: [id], onDelete: Cascade)
  task            Task?             @relation("TaskAttachments", fields: [task_id], references: [id], onDelete: SetNull)
  tags            TagOnAttachment[]

  @@index([user_id])
  @@index([task_id])
  @@index([parent_type, parent_id])
  @@index([user_id, reviewed])
  @@index([deleted_at])
}

// ─── TagOnAttachment (join) ──────────────────────────────────────────────────

model TagOnAttachment {
  attachment_id  String     @db.Uuid
  tag_id         String     @db.Uuid
  created_at     DateTime   @default(now()) @db.Timestamptz

  attachment     Attachment @relation(fields: [attachment_id], references: [id], onDelete: Cascade)
  tag            Tag        @relation(fields: [tag_id], references: [id], onDelete: Cascade)

  @@id([attachment_id, tag_id])
  @@index([tag_id])
}

// ─── Capture ─────────────────────────────────────────────────────────────────

model Capture {
  id           String    @id @db.Uuid
  user_id      String    @db.Uuid
  raw_text     String
  title        String?
  tags         String[]
  due_date     DateTime? @db.Timestamptz
  action_items String[]
  ai_parsed    Boolean   @default(false)
  deleted_at   DateTime? @db.Timestamptz
  created_at   DateTime  @default(now()) @db.Timestamptz
  updated_at   DateTime  @updatedAt @db.Timestamptz

  user         User      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([user_id, created_at])
  @@index([deleted_at])
}

// ─── Person (placeholder; full model in Wave 6) ──────────────────────────────

model Person {
  id           String    @id @db.Uuid
  user_id      String    @db.Uuid
  handle       String
  display_name String?
  email        String?
  deleted_at   DateTime? @db.Timestamptz
  created_at   DateTime  @default(now()) @db.Timestamptz
  updated_at   DateTime  @updatedAt @db.Timestamptz

  user         User      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, handle])
  @@index([user_id])
  @@index([deleted_at])
}

// ─── Tag ─────────────────────────────────────────────────────────────────────

model Tag {
  id          String    @id @db.Uuid
  user_id     String    @db.Uuid
  name        String
  color       String?
  usage_count Int       @default(0)
  deleted_at  DateTime? @db.Timestamptz
  created_at  DateTime  @default(now()) @db.Timestamptz
  updated_at  DateTime  @updatedAt @db.Timestamptz

  user        User      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  tasks       TagOnTask[]
  attachments TagOnAttachment[]

  @@unique([user_id, name])
  @@index([user_id])
  @@index([user_id, usage_count])
  @@index([deleted_at])
}

// ─── Context ─────────────────────────────────────────────────────────────────

model Context {
  id         String    @id @db.Uuid
  user_id    String    @db.Uuid
  name       String
  icon       String?
  color      String?
  position   Decimal   @default(0) @db.Decimal(20, 10)
  deleted_at DateTime? @db.Timestamptz
  created_at DateTime  @default(now()) @db.Timestamptz
  updated_at DateTime  @updatedAt @db.Timestamptz

  user       User      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  tasks      ContextOnTask[]

  @@unique([user_id, name])
  @@index([user_id])
  @@index([deleted_at])
}

// ─── ProjectFolder ────────────────────────────────────────────────────────────

model ProjectFolder {
  id          String    @id @db.Uuid
  user_id     String    @db.Uuid
  parent_id   String?   @db.Uuid
  name        String
  notes       String?
  position    Decimal   @default(0) @db.Decimal(20, 10)
  collapsed   Boolean   @default(false)
  deleted_at  DateTime? @db.Timestamptz
  created_at  DateTime  @default(now()) @db.Timestamptz
  updated_at  DateTime  @updatedAt @db.Timestamptz

  user        User            @relation(fields: [user_id], references: [id], onDelete: Cascade)
  parent      ProjectFolder?  @relation("FolderChildren", fields: [parent_id], references: [id], onDelete: SetNull)
  children    ProjectFolder[] @relation("FolderChildren")
  projects    Project[]

  @@index([user_id])
  @@index([user_id, parent_id])
  @@index([deleted_at])
}

// ─── Project ─────────────────────────────────────────────────────────────────

model Project {
  id                   String    @id @db.Uuid
  user_id              String    @db.Uuid
  folder_id            String?   @db.Uuid
  title                String
  notes                String?
  status               String    @default("active") // active | on_hold | completed | dropped
  color                String?
  sequential           Boolean   @default(false)
  position             Decimal   @default(0) @db.Decimal(20, 10)
  completed_at         DateTime? @db.Timestamptz
  last_reviewed_at     DateTime? @db.Timestamptz
  review_interval_days Int?      // null = Never; 3, 7, 14, 30
  deleted_at           DateTime? @db.Timestamptz
  created_at           DateTime  @default(now()) @db.Timestamptz
  updated_at           DateTime  @updatedAt @db.Timestamptz

  user        User           @relation(fields: [user_id], references: [id], onDelete: Cascade)
  folder      ProjectFolder? @relation(fields: [folder_id], references: [id], onDelete: SetNull)
  tasks       Task[]

  @@index([user_id])
  @@index([user_id, status])
  @@index([user_id, position])
  @@index([user_id, folder_id])
  @@index([deleted_at])
}

// ─── Task ────────────────────────────────────────────────────────────────────

model Task {
  id          String    @id @db.Uuid
  user_id     String    @db.Uuid
  project_id  String?   @db.Uuid
  parent_id   String?   @db.Uuid
  title       String
  notes       String?
  status      String    @default("active") // active | completed | dropped
  flagged     Boolean   @default(false)
  defer_date  DateTime? @db.Timestamptz
  due_date    DateTime? @db.Timestamptz
  completed_at DateTime? @db.Timestamptz
  estimated_minutes Int?
  position    Decimal   @default(0) @db.Decimal(20, 10)

  // Recurrence
  recurrence_rule      String?
  recurrence_anchor    String    @default("due_date") // due_date | completion_date
  recurrence_parent_id String?   @db.Uuid

  // Denormalized references derived by the parser from notes.
  referenced_person_ids  String[] @default([])
  referenced_tag_ids     String[] @default([])
  referenced_entity_refs Json?

  search_vector String?  // kept in sync by task_search_vector_trigger (title || ' ' || notes)

  deleted_at  DateTime? @db.Timestamptz
  created_at  DateTime  @default(now()) @db.Timestamptz
  updated_at  DateTime  @updatedAt @db.Timestamptz

  user             User      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  project          Project?  @relation(fields: [project_id], references: [id], onDelete: SetNull)
  parent           Task?     @relation("TaskSubtasks", fields: [parent_id], references: [id], onDelete: Cascade)
  subtasks         Task[]    @relation("TaskSubtasks")
  contexts         ContextOnTask[]
  tags             TagOnTask[]
  checklist_items  ChecklistItem[]
  work_logs        TaskWorkLog[]
  attachments      Attachment[] @relation("TaskAttachments")

  @@index([user_id])
  @@index([user_id, project_id])
  @@index([user_id, status])
  @@index([user_id, due_date])
  @@index([user_id, defer_date])
  @@index([user_id, flagged])
  @@index([user_id, parent_id])
  @@index([project_id, position])
  @@index([recurrence_parent_id])
  @@index([deleted_at])
}

// ─── ContextOnTask (join) ────────────────────────────────────────────────────

model ContextOnTask {
  task_id    String   @db.Uuid
  context_id String   @db.Uuid
  created_at DateTime @default(now()) @db.Timestamptz

  task       Task     @relation(fields: [task_id], references: [id], onDelete: Cascade)
  context    Context  @relation(fields: [context_id], references: [id], onDelete: Cascade)

  @@id([task_id, context_id])
  @@index([context_id])
}

// ─── TagOnTask (join) ────────────────────────────────────────────────────────

model TagOnTask {
  task_id    String   @db.Uuid
  tag_id     String   @db.Uuid
  created_at DateTime @default(now()) @db.Timestamptz

  task       Task     @relation(fields: [task_id], references: [id], onDelete: Cascade)
  tag        Tag      @relation(fields: [tag_id], references: [id], onDelete: Cascade)

  @@id([task_id, tag_id])
  @@index([tag_id])
}

// ─── EmailCapture ─────────────────────────────────────────────────────────────

model EmailCapture {
  id           String    @id @db.Uuid
  user_id      String    @db.Uuid
  from_address String
  to_address   String
  subject      String?
  body_text    String?
  body_html    String?
  message_id   String?   @unique
  received_at  DateTime  @db.Timestamptz
  status       String    @default("pending") // pending | processing | done | failed
  task_id      String?   @db.Uuid
  error        String?
  created_at   DateTime  @default(now()) @db.Timestamptz
  updated_at   DateTime  @updatedAt @db.Timestamptz

  user         User      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([user_id, status])
  @@index([received_at])
}

// ─── CaptureParseLog ──────────────────────────────────────────────────────────

model CaptureParseLog {
  id               String    @id @db.Uuid
  user_id          String    @db.Uuid
  task_id          String?   @db.Uuid
  raw_text         String
  parse_tier       String    // local_only | local_plus_ai | fallback_only
  local_confidence Float
  ai_used          Boolean   @default(false)
  ai_model         String?
  ai_input_tokens  Int?
  ai_output_tokens Int?
  ai_cost_usd      Float?
  parse_duration_ms Int
  title            String?
  due_date         DateTime? @db.Timestamptz
  tags             String[]  @default([])
  contexts         String[]  @default([])
  project_hint     String?
  ai_error         String?
  source           String    @default("modal") // modal | quick_add | email | api
  created_at       DateTime  @default(now()) @db.Timestamptz

  user             User      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([user_id, parse_tier])
  @@index([user_id, created_at])
  @@index([created_at])
}

// ─── WaitlistEntry ───────────────────────────────────────────────────────────

model WaitlistEntry {
  id         String   @id @db.Uuid
  name       String
  email      String   @unique
  message    String?
  status     String   @default("pending")
  created_at DateTime @default(now()) @db.Timestamptz

  @@index([email])
  @@index([created_at])
  @@index([status])
}

// ─── TaskWorkLog ──────────────────────────────────────────────────────────────

model TaskWorkLog {
  id               String    @id @db.Uuid
  user_id          String    @db.Uuid
  task_id          String    @db.Uuid
  body             String
  duration_minutes Int?
  deleted_at       DateTime? @db.Timestamptz
  created_at       DateTime  @default(now()) @db.Timestamptz
  updated_at       DateTime  @updatedAt @db.Timestamptz

  user             User      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  task             Task      @relation(fields: [task_id], references: [id], onDelete: Cascade)

  @@index([task_id, created_at])
  @@index([user_id, created_at])
  @@index([deleted_at])
}

// ─── DriveConfig ─────────────────────────────────────────────────────────────

model DriveConfig {
  id                      String   @id @db.Uuid
  user_id                 String   @unique @db.Uuid
  drive_type              String
  shared_drive_id         String?
  root_folder_id          String
  root_folder_name        String
  atlas_folder_id         String?
  folder_database_backups String?
  folder_notes            String?
  folder_journal          String?
  folder_attachments      String?
  verified                Boolean   @default(false)
  verified_at             DateTime? @db.Timestamptz
  created_at              DateTime  @default(now()) @db.Timestamptz
  updated_at              DateTime  @updatedAt @db.Timestamptz

  user                    User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
}

// ─── ChecklistItem ────────────────────────────────────────────────────────────

model ChecklistItem {
  id           String    @id @db.Uuid
  user_id      String    @db.Uuid
  task_id      String    @db.Uuid
  title        String
  completed_at DateTime? @db.Timestamptz
  position     Decimal   @default(0) @db.Decimal(20, 10)
  created_at   DateTime  @default(now()) @db.Timestamptz
  updated_at   DateTime  @updatedAt @db.Timestamptz
  deleted_at   DateTime? @db.Timestamptz

  user         User      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  task         Task      @relation(fields: [task_id], references: [id], onDelete: Cascade)

  @@index([task_id, position])
  @@index([user_id])
  @@index([deleted_at])
}
