  linked_project       Project?        @relation("CalendarEventProject", fields: [linked_project_id], references: [id], onDelete: SetNull)
  linked_note          Note?           @relation("CalendarEventNote", fields: [linked_note_id], references: [id], onDelete: SetNull)
  recurrence_master    CalendarEvent?  @relation("CalendarEventOverrides", fields: [recurrence_master_id], references: [id], onDelete: SetNull)
  overrides            CalendarEvent[] @relation("CalendarEventOverrides")
  attendees            CalendarEventAttendee[]

  @@unique([user_id, google_event_id, calendar_id])
  @@index([user_id])
  @@index([user_id, calendar_id])
  @@index([user_id, start_at, end_at])
  @@index([linked_task_id])
  @@index([linked_project_id])
  @@index([linked_note_id])
  @@index([recurrence_master_id])
  @@index([deleted_at])
}

// ─── CalendarEventAttendee ────────────────────────────────────────────────────

model CalendarEventAttendee {
  id              String        @id @db.Uuid
  event_id        String        @db.Uuid
  email           String
  display_name    String?
  response_status String        @default("needsAction") // accepted | declined | tentative | needsAction
  is_organizer    Boolean       @default(false)
  is_self         Boolean       @default(false)
  person_id       String?       @db.Uuid
  created_at      DateTime      @default(now()) @db.Timestamptz
  updated_at      DateTime      @updatedAt @db.Timestamptz

  event           CalendarEvent @relation(fields: [event_id], references: [id], onDelete: Cascade)
  person          Person?       @relation(fields: [person_id], references: [id], onDelete: SetNull)

  @@unique([event_id, email])
  @@index([event_id])
  @@index([person_id])
}
