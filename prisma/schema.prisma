// Atlas — Wave 1 schema.
// All PKs are UUIDv7. All timestamps are TIMESTAMPTZ.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── User ────────────────────────────────────────────────────────────────────
// MAINTENANCE NOTE: When adding a new table with a user_id column, you MUST
// also update reattachOrphanData() in src/core/auth/orphan-recovery.ts to
// include that table in the orphan reattachment transaction.

model User {
  id                      String    @id @db.Uuid
  clerk_id                String    @unique
  email                   String    @unique
  name                    String?
  image                   String?
  timezone                String    @default("UTC")
  locale_preset           String    @default("pakistan")
  language                String    @default("ur")
  currency_code           String    @default("PKR")
  currency_symbol         String    @default("₨")
  date_format             String    @default("DD/MM/YYYY")
  number_format           String    @default("1,234.56")
  time_format             String    @default("12h")
  week_start              String    @default("monday")
  theme                   String    @default("dark")
  tasks_prefs             Json?
  ai_confidence_threshold Float     @default(0.70)
  ai_budget_usd           Float?
  recovery_notification_pending Boolean   @default(false)
  last_recovery_summary         Json?
  last_recovery_dismissed_at    DateTime? @db.Timestamptz
  created_at              DateTime  @default(now()) @db.Timestamptz
  updated_at              DateTime  @updatedAt @db.Timestamptz
  deleted_at              DateTime? @db.Timestamptz

  audit_logs         AuditLog[]
  integration_tokens IntegrationToken[]
  sync_states        SyncState[]
  ai_call_logs       AICallLog[]
  attachments        Attachment[]
  drive_config       DriveConfig?
  captures           Capture[]
  email_captures     EmailCapture[]
  capture_parse_logs CaptureParseLog[]
  tasks              Task[]
  projects           Project[]
  project_folders    ProjectFolder[]
  contexts           Context[]
  tags               Tag[]
  people             Person[]
  checklist_items    ChecklistItem[]
  work_logs          TaskWorkLog[]
  notes              Note[]
  notes_folders      NotesFolder[]
  links              Link[]
  tables             Table[]
  tables_folders     TablesFolder[]

  @@index([clerk_id])
  @@index([email])
  @@index([deleted_at])
}

// ─── AuditLog ────────────────────────────────────────────────────────────────

model AuditLog {
  id          String   @id @db.Uuid
  user_id     String?  @db.Uuid
  entity_type String
  entity_id   String
  action      String
  diff        Json?
  meta        Json?
  created_at  DateTime @default(now()) @db.Timestamptz

  user        User?    @relation(fields: [user_id], references: [id], onDelete: SetNull)

  @@index([user_id])
  @@index([entity_type, entity_id])
  @@index([created_at])
}

// ─── IntegrationToken ────────────────────────────────────────────────────────

model IntegrationToken {
  id            String   @id @db.Uuid
  user_id       String   @db.Uuid
  provider      String
  encrypted_data String
  scopes        String[]
  expires_at    DateTime? @db.Timestamptz
  created_at    DateTime @default(now()) @db.Timestamptz
  updated_at    DateTime @updatedAt @db.Timestamptz

  user          User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, provider])
  @@index([user_id])
}

// ─── SyncState ───────────────────────────────────────────────────────────────

model SyncState {
  id            String   @id @db.Uuid
  user_id       String   @db.Uuid
  provider      String
  resource_type String
  cursor        String?
  last_synced   DateTime? @db.Timestamptz
  meta          Json?
  created_at    DateTime @default(now()) @db.Timestamptz
  updated_at    DateTime @updatedAt @db.Timestamptz

  user          User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, provider, resource_type])
  @@index([user_id])
}

// ─── RateLimitTracker ────────────────────────────────────────────────────────

model RateLimitTracker {
  id          String   @id @db.Uuid
  user_id     String   @db.Uuid
  provider    String
  window_start DateTime @db.Timestamptz
  request_count Int    @default(0)
  daily_count Int      @default(0)
  updated_at  DateTime @updatedAt @db.Timestamptz

  @@unique([user_id, provider, window_start])
  @@index([user_id, provider])
}

// ─── AICallLog ───────────────────────────────────────────────────────────────

model AICallLog {
  id            String   @id @db.Uuid
  user_id       String?  @db.Uuid
  task          String
  model         String
  input_tokens  Int?
  output_tokens Int?
  cost_usd      Float?
  duration_ms   Int?
  success       Boolean  @default(true)
  error         String?
  created_at    DateTime @default(now()) @db.Timestamptz

  user          User?    @relation(fields: [user_id], references: [id], onDelete: SetNull)

  @@index([user_id])
  @@index([created_at])
  @@index([user_id, created_at])
}

// ─── Attachment ──────────────────────────────────────────────────────────────

model Attachment {
  id              String    @id @db.Uuid
  user_id         String    @db.Uuid
  task_id         String?   @db.Uuid
  parent_type     String?
  parent_id       String?
  file_id         String    @unique
  filename        String
  content_type    String
  size_bytes      Int
  storage_path    String
  thumbnail_path  String?
  position        Decimal   @default(0) @db.Decimal(20, 10)
  description     String?
  reviewed        Boolean   @default(false)
  image_width     Int?
  image_height    Int?
  deleted_at      DateTime? @db.Timestamptz
  created_at      DateTime  @default(now()) @db.Timestamptz
  updated_at      DateTime  @updatedAt @db.Timestamptz

  user            User              @relation(fields: [user_id], references: [id], onDelete: Cascade)
  task            Task?             @relation("TaskAttachments", fields: [task_id], references: [id], onDelete: SetNull)
  tags            TagOnAttachment[]

  @@index([user_id])
  @@index([task_id])
  @@index([parent_type, parent_id])
  @@index([user_id, reviewed])
  @@index([deleted_at])
}

// ─── TagOnAttachment (join) ──────────────────────────────────────────────────

model TagOnAttachment {
  attachment_id  String     @db.Uuid
  tag_id         String     @db.Uuid
  created_at     DateTime   @default(now()) @db.Timestamptz

  attachment     Attachment @relation(fields: [attachment_id], references: [id], onDelete: Cascade)
  tag            Tag        @relation(fields: [tag_id], references: [id], onDelete: Cascade)

  @@id([attachment_id, tag_id])
  @@index([tag_id])
}

// ─── Capture ─────────────────────────────────────────────────────────────────

model Capture {
  id                String    @id @db.Uuid
  user_id           String    @db.Uuid
  raw_text          String
  title             String?
  tags              String[]
  due_date          DateTime? @db.Timestamptz
  action_items      String[]
  ai_parsed         Boolean   @default(false)

  // GTD Inbox Wave 1 fields
  state             String    @default("raw") // raw | proposed | processed
  processed_at      DateTime? @db.Timestamptz
  processed_to_type String?   // "task" | "project" | "reference" | "someday" | "deleted"
  processed_to_id   String?   @db.Uuid
  migration_source  String?   // e.g. "inbox_migration_v1"
  parser_proposal   Json?     // structured ParsedCapture output from parser

  deleted_at   DateTime? @db.Timestamptz
  created_at   DateTime  @default(now()) @db.Timestamptz
  updated_at   DateTime  @updatedAt @db.Timestamptz

  user         User      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([user_id, created_at])
  @@index([user_id, state])
  @@index([user_id, state, processed_at])
  @@index([deleted_at])
}

// ─── Person (placeholder; full model in Wave 6) ──────────────────────────────

model Person {
  id           String    @id @db.Uuid
  user_id      String    @db.Uuid
  handle       String
  display_name String?
  email        String?
  deleted_at   DateTime? @db.Timestamptz
  created_at   DateTime  @default(now()) @db.Timestamptz
  updated_at   DateTime  @updatedAt @db.Timestamptz

  user         User      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, handle])
  @@index([user_id])
  @@index([deleted_at])
}

// ─── Tag ─────────────────────────────────────────────────────────────────────

model Tag {
  id          String    @id @db.Uuid
  user_id     String    @db.Uuid
  name        String
  color       String?
  usage_count Int       @default(0)
  deleted_at  DateTime? @db.Timestamptz
  created_at  DateTime  @default(now()) @db.Timestamptz
  updated_at  DateTime  @updatedAt @db.Timestamptz

  user        User      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  tasks       TagOnTask[]
  attachments TagOnAttachment[]

  @@unique([user_id, name])
  @@index([user_id])
  @@index([user_id, usage_count])
  @@index([deleted_at])
}

// ─── Context ─────────────────────────────────────────────────────────────────

model Context {
  id         String    @id @db.Uuid
  user_id    String    @db.Uuid
  name       String
  icon       String?
  color      String?
  position   Decimal   @default(0) @db.Decimal(20, 10)
  deleted_at DateTime? @db.Timestamptz
  created_at DateTime  @default(now()) @db.Timestamptz
  updated_at DateTime  @updatedAt @db.Timestamptz

  user       User      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  tasks      ContextOnTask[]

  @@unique([user_id, name])
  @@index([user_id])
  @@index([deleted_at])
}

// ─── ProjectFolder ────────────────────────────────────────────────────────────

model ProjectFolder {
  id          String    @id @db.Uuid
  user_id     String    @db.Uuid
  parent_id   String?   @db.Uuid
  name        String
  notes       String?
  position    Decimal   @default(0) @db.Decimal(20, 10)
  collapsed   Boolean   @default(false)
  deleted_at  DateTime? @db.Timestamptz
  created_at  DateTime  @default(now()) @db.Timestamptz
  updated_at  DateTime  @updatedAt @db.Timestamptz

  user        User            @relation(fields: [user_id], references: [id], onDelete: Cascade)
  parent      ProjectFolder?  @relation("FolderChildren", fields: [parent_id], references: [id], onDelete: SetNull)
  children    ProjectFolder[] @relation("FolderChildren")
  projects    Project[]

  @@index([user_id])
  @@index([user_id, parent_id])
  @@index([deleted_at])
}

// ─── Project ─────────────────────────────────────────────────────────────────

model Project {
  id                   String    @id @db.Uuid
  user_id              String    @db.Uuid
  folder_id            String?   @db.Uuid
  title                String
  notes                String?
  type                 String    @default("project") // project | area
  status               String    @default("active") // active | on_hold | completed | dropped
  target_date          DateTime? @db.Timestamptz
  color                String?
  sequential           Boolean   @default(false)
  position             Decimal   @default(0) @db.Decimal(20, 10)
  completed_at         DateTime? @db.Timestamptz
  last_reviewed_at     DateTime? @db.Timestamptz
  review_interval_days Int?      // null = Never; 3, 7, 14, 30
  deleted_at           DateTime? @db.Timestamptz
  created_at           DateTime  @default(now()) @db.Timestamptz
  updated_at           DateTime  @updatedAt @db.Timestamptz

  user        User           @relation(fields: [user_id], references: [id], onDelete: Cascade)
  folder      ProjectFolder? @relation(fields: [folder_id], references: [id], onDelete: SetNull)
  tasks       Task[]
  note_refs   Note[]
  tables      Table[]

  @@index([user_id])
  @@index([user_id, type])
  @@index([user_id, status])
  @@index([user_id, position])
  @@index([user_id, folder_id])
  @@index([deleted_at])
}

// ─── Task ────────────────────────────────────────────────────────────────────

model Task {
  id          String    @id @db.Uuid
  user_id     String    @db.Uuid
  project_id  String?   @db.Uuid
  parent_id   String?   @db.Uuid
  title       String
  notes       String?
  status      String    @default("active") // active | completed | dropped
  flagged     Boolean   @default(false)
  defer_date  DateTime? @db.Timestamptz
  due_date    DateTime? @db.Timestamptz
  completed_at DateTime? @db.Timestamptz
  estimated_minutes Int?
  position    Decimal   @default(0) @db.Decimal(20, 10)

  // Recurrence
  recurrence_rule      String?
  recurrence_anchor    String    @default("due_date") // due_date | completion_date
  recurrence_parent_id String?   @db.Uuid

  // Denormalized references derived by the parser from notes.
  referenced_person_ids  String[] @default([])
  referenced_tag_ids     String[] @default([])
  referenced_entity_refs Json?

  search_vector String?  // kept in sync by task_search_vector_trigger (title || ' ' || notes)

  // GTD Inbox Wave 1 fields
  is_someday             Boolean   @default(false)
  someday_review_date    DateTime? @db.Timestamptz
  delegated_to_text      String?
  delegated_to_person_id String?   @db.Uuid
  follow_up_date         DateTime? @db.Timestamptz
  migration_note         String?

  deleted_at  DateTime? @db.Timestamptz
  created_at  DateTime  @default(now()) @db.Timestamptz
  updated_at  DateTime  @updatedAt @db.Timestamptz

  user             User      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  project          Project?  @relation(fields: [project_id], references: [id], onDelete: SetNull)
  parent           Task?     @relation("TaskSubtasks", fields: [parent_id], references: [id], onDelete: Cascade)
  subtasks         Task[]    @relation("TaskSubtasks")
  contexts         ContextOnTask[]
  tags             TagOnTask[]
  checklist_items  ChecklistItem[]
  work_logs        TaskWorkLog[]
  attachments      Attachment[] @relation("TaskAttachments")

  @@index([user_id])
  @@index([user_id, project_id])
  @@index([user_id, status])
  @@index([user_id, due_date])
  @@index([user_id, defer_date])
  @@index([user_id, flagged])
  @@index([user_id, parent_id])
  @@index([project_id, position])
  @@index([recurrence_parent_id])
  @@index([user_id, is_someday])
  @@index([user_id, follow_up_date])
  @@index([deleted_at])
}

// ─── ContextOnTask (join) ────────────────────────────────────────────────────

model ContextOnTask {
  task_id    String   @db.Uuid
  context_id String   @db.Uuid
  created_at DateTime @default(now()) @db.Timestamptz

  task       Task     @relation(fields: [task_id], references: [id], onDelete: Cascade)
  context    Context  @relation(fields: [context_id], references: [id], onDelete: Cascade)

  @@id([task_id, context_id])
  @@index([context_id])
}

// ─── TagOnTask (join) ────────────────────────────────────────────────────────

model TagOnTask {
  task_id    String   @db.Uuid
  tag_id     String   @db.Uuid
  created_at DateTime @default(now()) @db.Timestamptz

  task       Task     @relation(fields: [task_id], references: [id], onDelete: Cascade)
  tag        Tag      @relation(fields: [tag_id], references: [id], onDelete: Cascade)

  @@id([task_id, tag_id])
  @@index([tag_id])
}

// ─── EmailCapture ─────────────────────────────────────────────────────────────

model EmailCapture {
  id           String    @id @db.Uuid
  user_id      String    @db.Uuid
  from_address String
  to_address   String
  subject      String?
  body_text    String?
  body_html    String?
  message_id   String?   @unique
  received_at  DateTime  @db.Timestamptz
  status       String    @default("pending") // pending | processing | done | failed
  task_id      String?   @db.Uuid
  error        String?
  created_at   DateTime  @default(now()) @db.Timestamptz
  updated_at   DateTime  @updatedAt @db.Timestamptz

  user         User      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([user_id, status])
  @@index([received_at])
}

// ─── CaptureParseLog ──────────────────────────────────────────────────────────

model CaptureParseLog {
  id               String    @id @db.Uuid
  user_id          String    @db.Uuid
  task_id          String?   @db.Uuid
  raw_text         String
  parse_tier       String    // local_only | local_plus_ai | fallback_only
  local_confidence Float
  ai_used          Boolean   @default(false)
  ai_model         String?
  ai_input_tokens  Int?
  ai_output_tokens Int?
  ai_cost_usd      Float?
  parse_duration_ms Int
  title            String?
  due_date         DateTime? @db.Timestamptz
  tags             String[]  @default([])
  contexts         String[]  @default([])
  project_hint     String?
  ai_error         String?
  source           String    @default("modal") // modal | quick_add | email | api
  created_at       DateTime  @default(now()) @db.Timestamptz

  user             User      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([user_id, parse_tier])
  @@index([user_id, created_at])
  @@index([created_at])
}

// ─── WaitlistEntry ───────────────────────────────────────────────────────────

model WaitlistEntry {
  id         String   @id @db.Uuid
  name       String
  email      String   @unique
  message    String?
  status     String   @default("pending")
  created_at DateTime @default(now()) @db.Timestamptz

  @@index([email])
  @@index([created_at])
  @@index([status])
}

// ─── TaskWorkLog ──────────────────────────────────────────────────────────────

model TaskWorkLog {
  id               String    @id @db.Uuid
  user_id          String    @db.Uuid
  task_id          String    @db.Uuid
  body             String
  duration_minutes Int?
  deleted_at       DateTime? @db.Timestamptz
  created_at       DateTime  @default(now()) @db.Timestamptz
  updated_at       DateTime  @updatedAt @db.Timestamptz

  user             User      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  task             Task      @relation(fields: [task_id], references: [id], onDelete: Cascade)

  @@index([task_id, created_at])
  @@index([user_id, created_at])
  @@index([deleted_at])
}

// ─── DriveConfig ─────────────────────────────────────────────────────────────

model DriveConfig {
  id                      String   @id @db.Uuid
  user_id                 String   @unique @db.Uuid
  drive_type              String
  shared_drive_id         String?
  root_folder_id          String
  root_folder_name        String
  atlas_folder_id         String?
  folder_database_backups String?
  folder_notes            String?
  folder_journal          String?
  folder_attachments      String?
  folder_tables           String?
  verified                Boolean   @default(false)
  verified_at             DateTime? @db.Timestamptz
  created_at              DateTime  @default(now()) @db.Timestamptz
  updated_at              DateTime  @updatedAt @db.Timestamptz

  user                    User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
}

// ─── ChecklistItem ────────────────────────────────────────────────────────────

model ChecklistItem {
  id           String    @id @db.Uuid
  user_id      String    @db.Uuid
  task_id      String    @db.Uuid
  title        String
  completed_at DateTime? @db.Timestamptz
  position     Decimal   @default(0) @db.Decimal(20, 10)
  created_at   DateTime  @default(now()) @db.Timestamptz
  updated_at   DateTime  @updatedAt @db.Timestamptz
  deleted_at   DateTime? @db.Timestamptz

  user         User      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  task         Task      @relation(fields: [task_id], references: [id], onDelete: Cascade)

  @@index([task_id, position])
  @@index([user_id])
  @@index([deleted_at])
}

// ─── NotesFolder ─────────────────────────────────────────────────────────────

model NotesFolder {
  id         String    @id @db.Uuid
  user_id    String    @db.Uuid
  parent_id  String?   @db.Uuid
  name       String
  position   Decimal   @default(0) @db.Decimal(20, 10)
  deleted_at DateTime? @db.Timestamptz
  created_at DateTime  @default(now()) @db.Timestamptz
  updated_at DateTime  @updatedAt @db.Timestamptz

  user       User          @relation(fields: [user_id], references: [id], onDelete: Cascade)
  parent     NotesFolder?  @relation("FolderHierarchy", fields: [parent_id], references: [id], onDelete: SetNull)
  children   NotesFolder[] @relation("FolderHierarchy")
  notes      Note[]

  @@index([user_id])
  @@index([user_id, parent_id])
  @@index([deleted_at])
}

// ─── Note ────────────────────────────────────────────────────────────────────

model Note {
  id                String    @id @db.Uuid
  user_id           String    @db.Uuid
  folder_id         String?   @db.Uuid
  project_id        String?   @db.Uuid
  title             String    @default("")
  body_json         String    @default("{}") // TipTap document JSON serialised as text
  body_text         String    @default("")   // Plain text extracted from body_json for FTS
  body_markdown     String    @default("")   // Markdown representation for Drive export
  purpose           String    @default("note") // note | meeting_note | project_brief | reading_note
  is_project_brief  Boolean   @default(false)
  pinned            Boolean   @default(false)
  position          Decimal   @default(0) @db.Decimal(20, 10)
  word_count        Int       @default(0)
  drive_file_id     String?
  drive_synced_at   DateTime? @db.Timestamptz
  drive_sync_error  String?
  imported_from     String?   // "md" | "docx" | null
  imported_at       DateTime? @db.Timestamptz
  source_metadata   Json?     // frontmatter fields, docx warnings, etc.
  deleted_at        DateTime? @db.Timestamptz
  created_at        DateTime  @default(now()) @db.Timestamptz
  updated_at        DateTime  @updatedAt @db.Timestamptz

  user              User         @relation(fields: [user_id], references: [id], onDelete: Cascade)
  folder            NotesFolder? @relation(fields: [folder_id], references: [id], onDelete: SetNull)
  project           Project?     @relation(fields: [project_id], references: [id], onDelete: SetNull)

  // Partial unique index (only one brief per project) is enforced via raw SQL:
  // CREATE UNIQUE INDEX note_project_brief_unique ON "Note" (project_id) WHERE is_project_brief = true;
  @@index([user_id])
  @@index([user_id, folder_id])
  @@index([user_id, project_id])
  @@index([user_id, purpose])
  @@index([user_id, pinned])
  @@index([deleted_at])
}

// ─── Link ────────────────────────────────────────────────────────────────────

model Link {
  id              String   @id @db.Uuid
  user_id         String   @db.Uuid
  source_type     String
  source_id       String   @db.Uuid
  target_type     String
  target_id       String   @db.Uuid
  relation        String   @default("reference") // reference | blocks | related
  source_excerpt  String?  // Short text snippet surrounding the reference in the source
  created_at      DateTime @default(now()) @db.Timestamptz

  user            User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([source_type, source_id, target_type, target_id])
  @@index([user_id])
  @@index([source_type, source_id])
  @@index([target_type, target_id])
}

// ─── TablesFolder ─────────────────────────────────────────────────────────────

model TablesFolder {
  id         String    @id @db.Uuid
  user_id    String    @db.Uuid
  parent_id  String?   @db.Uuid
  name       String
  position   Decimal   @default(0) @db.Decimal(20, 10)
  deleted_at DateTime? @db.Timestamptz
  created_at DateTime  @default(now()) @db.Timestamptz
  updated_at DateTime  @updatedAt @db.Timestamptz

  user       User           @relation(fields: [user_id], references: [id], onDelete: Cascade)
  parent     TablesFolder?  @relation("TablesFolderHierarchy", fields: [parent_id], references: [id], onDelete: SetNull)
  children   TablesFolder[] @relation("TablesFolderHierarchy")
  tables     Table[]

  @@index([user_id])
  @@index([user_id, parent_id])
  @@index([deleted_at])
}

// ─── Table ────────────────────────────────────────────────────────────────────

model Table {
  id                String    @id @db.Uuid
  user_id           String    @db.Uuid
  folder_id         String?   @db.Uuid
  project_id        String?   @db.Uuid
  name              String
  description       String?
  manual_row_order  Json      @default("[]") // array of row IDs in manual order
  drive_csv_file_id  String?
  drive_json_file_id String?
  drive_synced_at   DateTime? @db.Timestamptz
  drive_sync_error  String?
  deleted_at        DateTime? @db.Timestamptz
  created_at        DateTime  @default(now()) @db.Timestamptz
  updated_at        DateTime  @updatedAt @db.Timestamptz

  user    User          @relation(fields: [user_id], references: [id], onDelete: Cascade)
  folder  TablesFolder? @relation(fields: [folder_id], references: [id], onDelete: SetNull)
  project Project?      @relation(fields: [project_id], references: [id], onDelete: SetNull)
  columns TableColumn[]
  rows    TableRow[]

  @@index([user_id])
  @@index([user_id, folder_id])
  @@index([user_id, project_id])
  @@index([deleted_at])
}

// ─── TableColumn ──────────────────────────────────────────────────────────────

model TableColumn {
  id          String    @id @db.Uuid
  table_id    String    @db.Uuid
  name        String
  type        String    // text | number | date | checkbox | single_select | currency
  position    Decimal   @default(0) @db.Decimal(20, 10)
  config      Json      @default("{}") // type-specific config: { options, decimal_places, etc. }
  aggregation String?   // sum | average | count | min | max | checked_ratio | none
  width       Int       @default(160)
  deleted_at  DateTime? @db.Timestamptz
  created_at  DateTime  @default(now()) @db.Timestamptz
  updated_at  DateTime  @updatedAt @db.Timestamptz

  table  Table       @relation(fields: [table_id], references: [id], onDelete: Cascade)
  cells  TableCell[]

  @@index([table_id])
  @@index([table_id, position])
  @@index([deleted_at])
}

// ─── TableRow ─────────────────────────────────────────────────────────────────

model TableRow {
  id         String    @id @db.Uuid
  table_id   String    @db.Uuid
  position   Decimal   @default(0) @db.Decimal(20, 10)
  deleted_at DateTime? @db.Timestamptz
  created_at DateTime  @default(now()) @db.Timestamptz
  updated_at DateTime  @updatedAt @db.Timestamptz

  table  Table       @relation(fields: [table_id], references: [id], onDelete: Cascade)
  cells  TableCell[]

  @@index([table_id])
  @@index([table_id, position])
  @@index([deleted_at])
}

// ─── TableCell ────────────────────────────────────────────────────────────────

model TableCell {
  id         String   @id @db.Uuid
  row_id     String   @db.Uuid
  column_id  String   @db.Uuid
  value      Json?    // type-specific JSON value
  created_at DateTime @default(now()) @db.Timestamptz
  updated_at DateTime @updatedAt @db.Timestamptz

  row    TableRow    @relation(fields: [row_id], references: [id], onDelete: Cascade)
  column TableColumn @relation(fields: [column_id], references: [id], onDelete: Cascade)

  @@unique([row_id, column_id])
  @@index([row_id])
  @@index([column_id])
}
