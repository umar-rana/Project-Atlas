// ─── Note ────────────────────────────────────────────────────────────────────

model Note {
  id                String    @id @db.Uuid
  user_id           String    @db.Uuid
  folder_id         String?   @db.Uuid
  project_id        String?   @db.Uuid
  title             String    @default("")
  body_json         String    @default("{}") // TipTap document JSON serialised as text
  body_text         String    @default("")   // Plain text extracted from body_json for FTS
  body_markdown     String    @default("")   // Markdown representation for Drive export
  purpose           String    @default("note") // note | meeting_note | project_brief | reading_note
  is_project_brief  Boolean   @default(false)
  pinned            Boolean   @default(false)
  position          Decimal   @default(0) @db.Decimal(20, 10)
  word_count        Int       @default(0)
  drive_file_id     String?
  drive_synced_at   DateTime? @db.Timestamptz
  drive_sync_error  String?
  imported_from     String?   // "md" | "docx" | null
  imported_at       DateTime? @db.Timestamptz
  source_metadata   Json?     // frontmatter fields, docx warnings, etc.
  deleted_at        DateTime? @db.Timestamptz
  created_at        DateTime  @default(now()) @db.Timestamptz
  updated_at        DateTime  @updatedAt @db.Timestamptz

  user              User         @relation(fields: [user_id], references: [id], onDelete: Cascade)
  folder            NotesFolder? @relation(fields: [folder_id], references: [id], onDelete: SetNull)
  project           Project?     @relation(fields: [project_id], references: [id], onDelete: SetNull)
  tag_on_notes      TagOnNote[]
  versions          NoteVersion[]
  calendar_events   CalendarEvent[] @relation("CalendarEventNote")

  // search_vector is maintained by note_search_vector_trigger (title || ' ' || body_text).
  // It stores a precomputed tsvector for fast full-text search without inline to_tsvector() calls.
  search_vector Unsupported("tsvector")?

  // ── Manually-managed indexes (not representable in Prisma schema syntax) ──────
  //
  // Migration: 20260508000000_pg_trgm_and_search_vector
  //   Extension: pg_trgm (enables gin_trgm_ops operator class)
  //
  // Migration: 20260508000001_pg_trgm_gin_indexes
  //   note_search_vector_idx  — "Note" USING gin(search_vector)          WHERE deleted_at IS NULL
  //   note_title_trgm_idx     — "Note" USING gin(title gin_trgm_ops)     WHERE deleted_at IS NULL
  //   note_body_text_trgm_idx — "Note" USING gin(body_text gin_trgm_ops) WHERE deleted_at IS NULL
  //   task_title_trgm_idx     — "Task" USING gin(title gin_trgm_ops)     WHERE deleted_at IS NULL
  //   task_notes_trgm_idx     — "Task" USING gin(notes gin_trgm_ops)     WHERE deleted_at IS NULL
  //
  //   note_search_vector_idx is used by the Note FTS path in src/server/routers/search.ts
  //   note_title_trgm_idx / note_body_text_trgm_idx are used by the Note ILIKE fallback path
  //   task_title_trgm_idx / task_notes_trgm_idx are used by the Task ILIKE fallback path
  //
  // Partial unique index (only one brief per project) is enforced via raw SQL:
  // CREATE UNIQUE INDEX note_project_brief_unique ON "Note" (project_id) WHERE is_project_brief = true;
  @@index([user_id])
  @@index([user_id, folder_id])
  @@index([user_id, project_id])
  @@index([user_id, purpose])
  @@index([user_id, pinned])
  @@index([deleted_at])
}

