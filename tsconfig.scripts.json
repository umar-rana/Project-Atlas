{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["esnext"],
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": false,
    "outDir": ".scripts-dist"
  },
  "include": ["scripts/**/*.ts"],
  "exclude": ["node_modules"]
}
