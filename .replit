modules = ["nodejs-20", "python-3.11", "postgresql-16"]
[agent]
expertMode = true
integrations = ["javascript_log_in_with_replit:2.0.0", "javascript_object_storage:2.0.0", "javascript_anthropic_ai_integrations:2.0.0"]

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Storybook"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run dev"
waitForPort = 5000

[[workflows.workflow]]
name = "Storybook"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run storybook -- -p 6000"
waitForPort = 6000

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 6000
externalPort = 6000


[objectStorage]
defaultBucketID = "replit-objstore-0ec8f073-2ac5-491c-ada7-f8e45d7919c9"

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 240000

[userenv]

[userenv.shared]
LOG_LEVEL = "debug"
GOOGLE_REDIRECT_URI = "https://atlas.insightive.io/api/drive/oauth-callback"
STORAGE_PROVIDER = "r2"

[userenv.development]
APP_URL = "https://589c0f2c-f9be-408b-abb6-984853e85b49-00-2yh90adfura7a.sisko.replit.dev"
E2E_AUTH_SECRET = "atlas-e2e-smoke-test-secret-key-dev-only-2026"

[userenv.production]
APP_URL = "https://atlas.insightive.io"

[deployment]
deploymentTarget = "autoscale"
run = ["npm", "run", "start"]
build = ["npm", "run", "build"]
