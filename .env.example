# =============================================================
# Atlas — environment variables
# Copy to `.env` for local dev. Never commit `.env`.
# Wave 0 ships placeholders only; Wave 1+ wires the actual integrations.
# =============================================================

# --- Application ----------------------------------------------
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:5000

# --- Database (Wave 1) ----------------------------------------
# Replit Postgres or external provider; pick a connection pooler URL for serverless.
DATABASE_URL=

# --- Auth.js v5 (Wave 1) --------------------------------------
# Generate with: openssl rand -base64 32
AUTH_SECRET=
AUTH_URL=http://localhost:5000

# --- AI provider abstraction (Wave 1) -------------------------
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- Logging --------------------------------------------------
LOG_LEVEL=info
