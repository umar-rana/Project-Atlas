# =============================================================
# Atlas — Wave 1 environment variables
# Copy to .env.local for local dev. Never commit .env.local.
# =============================================================

# --- Application ----------------------------------------------
NODE_ENV=development

# --- Database -------------------------------------------------
# Provided automatically by Replit Postgres integration
DATABASE_URL=

# --- Session --------------------------------------------------
# Used for Drive OAuth CSRF HMAC nonce signing (src/app/api/drive/)
# Generate: openssl rand -hex 32
SESSION_SECRET=

# --- Replit environment ---------------------------------------
REPLIT_DEV_DOMAIN=
# Optional: hardcoded public base URL used as a last-resort fallback when
# x-forwarded-host and host headers are missing (e.g. on a custom domain).
# Example: https://atlas.insightive.io
APP_URL=

# --- AI (Anthropic via Replit integration) --------------------
# Set automatically when Anthropic blueprint is connected
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=

# --- Google Drive Integration ---------------------------------
# Create OAuth 2.0 credentials at console.cloud.google.com
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Must match exactly what is registered in Google Console
GOOGLE_REDIRECT_URI=https://your-repl.replit.app/api/drive/oauth-callback

# --- Object Storage -------------------------------------------
# Provided automatically by Replit Object Storage integration
DEFAULT_OBJECT_STORAGE_BUCKET_ID=
PRIVATE_OBJECT_DIR=
PUBLIC_OBJECT_SEARCH_PATHS=

# --- Drive Token Encryption -----------------------------------
# Generate: openssl rand -hex 32  (stored in .env.local, gitignored)
TOKEN_ENCRYPTION_KEY=

# --- Logging --------------------------------------------------
LOG_LEVEL=info

# --- End-to-end testing (CI ONLY — never set in production) ---
# When set with length >= 32, enables /api/auth/test-login so the e2e
# script can mint a session for a deterministic test user without going
# through Replit OIDC. Leave EMPTY in production: the route 404s when
# this var is unset, so the bypass simply doesn't exist.
E2E_AUTH_SECRET=
# Defense-in-depth opt-in. The route ALSO 404s when NODE_ENV=production
# unless this is set to "1". CI sets both because `next start` forces
# NODE_ENV=production. NEVER set this in the real production deployment.
E2E_ALLOW_IN_PRODUCTION=
