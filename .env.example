# =============================================================
# Atlas — Wave 1 environment variables
# Copy to .env.local for local dev. Never commit .env.local.
# =============================================================

# --- Application ----------------------------------------------
NODE_ENV=development

# --- Database -------------------------------------------------
# Provided automatically by Replit Postgres integration
DATABASE_URL=

# --- Session --------------------------------------------------
# Generate: openssl rand -hex 32
SESSION_SECRET=

# --- Replit OIDC ----------------------------------------------
# Auto-provided by Replit environment
REPL_ID=
REPLIT_DEV_DOMAIN=

# --- AI (Anthropic via Replit integration) --------------------
# Set automatically when Anthropic blueprint is connected
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=

# --- Google Drive Integration ---------------------------------
# Create OAuth 2.0 credentials at console.cloud.google.com
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Must match exactly what is registered in Google Console
GOOGLE_REDIRECT_URI=https://your-repl.replit.app/api/drive/oauth-callback

# --- Object Storage -------------------------------------------
# Provided automatically by Replit Object Storage integration
DEFAULT_OBJECT_STORAGE_BUCKET_ID=
PRIVATE_OBJECT_DIR=
PUBLIC_OBJECT_SEARCH_PATHS=

# --- Drive Token Encryption -----------------------------------
# Generate: openssl rand -hex 32  (stored in .env.local, gitignored)
TOKEN_ENCRYPTION_KEY=

# --- Logging --------------------------------------------------
LOG_LEVEL=info
